<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Items List</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
      <a href="/" class="navbar-brand">⬅ Back to Home</a>
      <a href="/add_service" class="btn btn-success">+ Add New Item</a>
    </div>
  </nav>

  <div class="container my-5">
    <h3 class="mb-4 text-center fw-bold">Items List</h3>

    <div class="table-responsive">
      <table class="table table-bordered table-hover align-middle bg-white">
        <thead class="table-dark text-center">
          <tr>
            <th>Sr No</th>
            <th>Heading</th>
            <th>Description</th>
            <th>View</th>
            <th>Image</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% result.map(function(item, index){ %>
            <tr class="text-center">
              <td><%= index + 1 %></td>
              <td><%= item.heading %></td>
              <td><%= item.desc %></td>
              <td><%= item.view %></td>
              <td>
                <img src="/<%= item.img %>" class="img-thumbnail" style="width:120px; height:80px;">
              </td>
              <td>
                <a href="/edit_service/<%= item.id %>" class="btn btn-sm btn-warning me-1"><i class="fas fa-edit"></i> Edit</a>
                <a href="/delete_service/<%= item.id %>" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i> Delete</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
