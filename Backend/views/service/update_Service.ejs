<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Update Item</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
      <a href="/list_service" class="navbar-brand">⬅ Back to List</a>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="card shadow border-0">
      <div class="card-header bg-warning text-white">
        <h4 class="mb-0"><i class="fas fa-edit"></i> Update Item</h4>
      </div>
      <div class="card-body">
        <form action="/update_service" method="post" enctype="multipart/form-data">
          <input type="hidden" name="id" value="<%= result[0].id %>">

          <div class="mb-3">
            <label class="form-label fw-bold">Heading</label>
            <input type="text" name="heading" class="form-control" value="<%= result[0].heading %>" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Description</label>
            <textarea name="desc" class="form-control" rows="4" required><%= result[0].desc %></textarea>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">View</label>
            <input type="text" name="view" class="form-control" value="<%= result[0].view %>" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Image</label>
            <input type="file" name="img" class="form-control" accept="image/*">
          </div>

          <button class="btn btn-warning w-100 mt-3">Update Item</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
