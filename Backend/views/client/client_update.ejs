<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Edit Client</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a href="/client_list" class="navbar-brand">⬅ Back to List</a>
  </div>
</nav>

<div class="container mt-5">

  <div class="card shadow border-0">
    <div class="card-header bg-warning text-white">
      <h4>Edit Client</h4>
    </div>

    <div class="card-body">

      <form action="/update_client" method="post" enctype="multipart/form-data">

        <input type="hidden" name="id" value="<%= result[0].id %>">

        <div class="mb-3">
          <label class="fw-bold">Old Logo</label><br>
          <img src="/<%= result[0].client_logo %>" height="60">

          <input type="file" name="client_logo" class="form-control mt-2">
        </div>

        <div class="mb-3">
          <label class="fw-bold">Old Image</label><br>
          <img src="/<%= result[0].client_img %>" height="60">

          <input type="file" name="client_img" class="form-control mt-2">
        </div>

        <div class="mb-3">
          <label class="fw-bold">Client Name</label>
          <input type="text" name="client_name" value="<%= result[0].client_name %>" class="form-control">
        </div>

        <div class="mb-3">
          <label class="fw-bold">Description</label>
          <input type="text" name="client_desc" value="<%= result[0].client_desc %>" class="form-control">
        </div>

        <div class="mb-3">
          <label class="fw-bold">Address</label>
          <textarea name="client_add" class="form-control"><%= result[0].client_add %></textarea>
        </div>

        <button class="btn btn-warning w-100">Update Client</button>

      </form>

    </div>
  </div>
</div>

</body>
</html>
