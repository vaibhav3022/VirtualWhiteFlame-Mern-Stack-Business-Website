<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Add Client</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a href="/" class="navbar-brand">⬅ Back to Home</a>
  </div>
</nav>

<div class="container mt-5">
  <div class="card shadow border-0">
    <div class="card-header bg-primary text-white">
      <h4 class="mb-0">Add New Client</h4>
    </div>

    <div class="card-body">
      <form action="/save_client" method="post" enctype="multipart/form-data">

        <div class="mb-3">
          <label class="form-label fw-bold">Client Logo</label>
          <input type="file" name="client_logo" class="form-control" required>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Client Image</label>
          <input type="file" name="client_img" class="form-control" required>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Client Name</label>
          <input type="text" name="client_name" class="form-control" required>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Description</label>
          <input type="text" name="client_desc" class="form-control" required>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Address</label>
          <textarea name="client_add" class="form-control" required></textarea>
        </div>

        <button class="btn btn-primary w-100">Add Client</button>
      </form>
    </div>

  </div>
</div>

</body>
</html>


