<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Client List</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a href="/" class="navbar-brand">⬅ Back to Home</a>
     <a href="/add_client" class="navbar-brand">⬅ Add New Client</a>
  </div>
</nav>

<div class="container mt-5">
  <h3 class="text-center fw-bold mb-4">Client List</h3>

  <table class="table table-bordered table-striped text-center">
    <thead class="table-dark">
      <tr>
        <th>ID</th>
        <th>Logo</th>
        <th>Image</th>
        <th>Name</th>
        <th>Description</th>
        <th>Address</th>
        <th>Action</th>
      </tr>
    </thead>

    <tbody>
      <% result.forEach((row)=>{ %>
        <tr>
          <td><%= row.id %></td>

          <td><img src="/<%= row.client_logo %>" height="60"></td>

          <td><img src="/<%= row.client_img %>" height="60"></td>

          <td><%= row.client_name %></td>
          <td><%= row.client_desc %></td>
          <td><%= row.client_add %></td>

          <td>
            <a href="/edit_client/<%= row.id %>" class="btn btn-warning btn-sm">Edit</a>
            <a href="/delete_client/<%= row.id %>" class="btn btn-danger btn-sm">Delete</a>
          </td>
        </tr>
      <% }) %>
    </tbody>

  </table>

</div>

</body>
</html>
