<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Add Counting</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
      <a href="/" class="navbar-brand">⬅ Back to Home</a>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="card shadow border-0">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="fas fa-plus-circle"></i> Add New Plants</h4>
      </div>
      <div class="card-body">
        <form action="/save_counting" method="post" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label fw-bold">Counting Name</label>
            <input type="text" name="counting_name" class="form-control" placeholder="Enter Counting  Name" required>
          </div>


          <div class="mb-3">
            <label class="form-label fw-bold">Count</label>
            <input type="text" name="counting_count" class="form-control" placeholder="Enter Counting Count" required>
          </div>
          
         

          <button class="btn btn-primary w-100 mt-3">Add Count</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>


