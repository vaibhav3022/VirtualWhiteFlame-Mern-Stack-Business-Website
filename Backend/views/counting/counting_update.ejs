<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Update Counting</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
      <a href="/counting_list" class="navbar-brand">⬅ Back to List</a>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="card shadow border-0">
      <div class="card-header bg-warning text-white">
        <h4 class="mb-0"><i class="fas fa-edit"></i> Update Counting</h4>
      </div>
      <div class="card-body">
        <form action="/update_counting" method="post" enctype="multipart/form-data">
          <input type="hidden" name="id" value="<%= result[0].id %>">

          <div class="mb-3">
            <label class="form-label fw-bold">Counting Name</label>
            <input type="text" name="counting_name" class="form-control" value="<%= result[0].counting_name %>">
          </div>

         

          <div class="mb-3">
            <label class="form-label fw-bold">Counting Count</label>
            <input type="text" name="counting_count" class="form-control" value="<%= result[0].counting_count %>">
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Description</label>
            <textarea name="counting_desc" class="form-control" rows="3"><%= result[0].counting_desc %></textarea>
          </div>

          
          <button class="btn btn-warning w-100 mt-3">Update Count</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
