<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add About Image</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a href="/service_img" class="navbar-brand">⬅ Back</a>
  </div>
</nav>

<div class="container mt-5">
  <div class="card shadow border-0">
    <div class="card-header bg-primary text-white">
      <h4>Add About Image</h4>
    </div>

    <div class="card-body">
      <form action="/save_service_img" method="post" enctype="multipart/form-data">

        <div class="mb-3">
          <label class="form-label fw-bold">Service Image</label>
          <input type="file" name="service_img" class="form-control mb-2" required>
          <textarea name="description" class="form-control" placeholder="Image Description"></textarea>
        </div>

        <button class="btn btn-primary w-100">Add Image</button>

      </form>
    </div>
  </div>
</div>

</body>
</html>

