<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Update Contact Image</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
      <a href="/contact_img_list" class="navbar-brand">⬅ Back to List</a>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="card shadow border-0">
      <div class="card-header bg-warning text-white">
        <h4 class="mb-0">Update Contact Image</h4>
      </div>
      <div class="card-body">
        <form action="/update_contact_img" method="post" enctype="multipart/form-data">
          <input type="hidden" name="id" value="<%= result[0].id %>">

          <div class="mb-3">
            <label class="form-label fw-bold">Change Image</label>
            <input type="file" name="contact_img" class="form-control mb-2">
            <textarea name="description" class="form-control" placeholder="Image Description"><%= result[0].description %></textarea>
            <p class="mt-2">Current Image:</p>
            <img src="/<%= result[0].contact_img %>" width="120" height="100">
          </div>

          <button class="btn btn-warning w-100 mt-3">Update Image</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
