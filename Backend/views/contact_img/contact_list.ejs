<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Contact Image List</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
      <a href="/" class="navbar-brand">⬅ Back to Home</a>
      <a href="/add_contact_img" class="btn btn-success">+ Add Contact Image</a>
    </div>
  </nav>

  <div class="container mt-5">
    <h3 class="text-center mb-4 fw-bold">All Contact Images</h3>

    <table class="table table-bordered table-striped text-center">
      <thead class="table-dark">
        <tr>
          <th>ID</th>
          <th>Image</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% result.forEach(function(row){ %>
        <tr>
          <td><%= row.id %></td>
          <td><img src="/<%= row.contact_img %>" width="100" height="80"></td>
          <td>
            <a href="/edit_contact_img/<%= row.id %>" class="btn btn-warning btn-sm">Edit</a>
            <a href="/delete_contact_img/<%= row.id %>" class="btn btn-danger btn-sm">Delete</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>
