<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <style>
    body {
      font-family: "Poppins", sans-serif;
      background-color: #f5f6fa;
      overflow-x: hidden;
    }

    /* Sidebar Styling */
    .sidebar {
      height: 100vh;
      width: 250px;
      background: #ffffff;
      border-right: 1px solid #dee2e6;
      position: fixed;
      top: 0;
      left: 0;
      overflow-y: auto;
      transition: all 0.3s ease;
      z-index: 1000;
    }

    .sidebar .navbar-brand {
      font-size: 1.5rem;
      color: #0d6efd;
    }

    .sidebar .nav-link {
      color: #333;
      font-weight: 500;
      padding: 12px 20px;
      transition: all 0.2s ease-in-out;
    }

    .sidebar .nav-link:hover,
    .sidebar .nav-link.active {
      background-color: #0d6efd;
      color: #fff;
      border-radius: 5px;
    }

    .sidebar .nav-link i {
      margin-right: 10px;
    }

    /* Content Area */
    .content {
      margin-left: 250px;
      padding: 20px;
      transition: all 0.3s ease;
    }

    /* Top Navbar */
    .topbar {
      background-color: #0d6efd;
      color: #fff;
      padding: 12px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 900;
    }

    .topbar .toggle-btn {
      font-size: 1.4rem;
      cursor: pointer;
    }

    /* Responsive */
    @media (max-width: 991px) {
      .sidebar {
        left: -250px;
      }
      .sidebar.active {
        left: 0;
      }
      .content {
        margin-left: 0;
      }
    }
  </style>
</head>
<body>

  <!-- Sidebar -->
  <nav class="sidebar" id="sidebarMenu">
    <div class="text-center py-3 border-bottom">
      <a class="navbar-brand fw-bold" href="/">🌿 Admin</a>
    </div>

    <ul class="nav flex-column px-2 mt-3">
       <li class="nav-item">
        <a class="nav-link " href="/home"><i class="fas fa-seedling"></i> Home Page</a>
      </li>
     <li class="nav-item">
        <a class="nav-link " href="/about"><i class="fas fa-seedling"></i> About Page</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/services"><i class="fas fa-chart-bar"></i> Services Page</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/gallery"><i class="fas fa-cogs"></i> Gallery Page</a>
      </li>
       <li class="nav-item">
        <a class="nav-link" href="/contact"><i class="fas fa-cogs"></i> Contact Page</a>
      </li>
    </ul>

  
  </nav>

  <!-- Top Navbar -->
  <div class="topbar">
    <span class="toggle-btn text-white" id="menuToggle"><i class="fas fa-bars"></i></span>
    <h5 class="mb-0">Admin Dashboard</h5>
    <div>
      <i class="fas fa-user-circle fs-4 me-3"></i>
    </div>
  </div>

  <!-- Main Content -->
  <div class="content">
    <div class="container-fluid">
      <div class="card shadow-sm border-0 p-4">
        <h3 class="fw-bold text-primary text-center">Welcome to Gallery Page Admin Panel</h3>
        <div class="row mt-4">
          <div class="col-md-6">
            <div class="card border-0 shadow-sm text-center p-4">
              <i class="fas fa-sliders-h fa-2x text-primary mb-2"></i>
              <h5>Manage Gallery Image</h5>
              <a href="/gallerys" class="btn btn-sm btn-primary mt-2">View</a>
            </div>
          </div>

          <div class="col-md-6">
            <div class="card border-0 shadow-sm text-center p-4">
              <i class="fas fa-sliders-h fa-2x text-primary mb-2"></i>
              <h5>Manage  Image</h5>
              <a href="/gallery_img" class="btn btn-sm btn-primary mt-2">View</a>
            </div>
          </div>
          

        


         


        </div>
      </div>
    </div>
  </div>

  <script>
    // Sidebar toggle for mobile
    const menuToggle = document.getElementById('menuToggle');
    const sidebarMenu = document.getElementById('sidebarMenu');
    menuToggle.addEventListener('click', () => {
      sidebarMenu.classList.toggle('active');
    });
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
