<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="bg-slate-50 text-slate-900 antialiased font-['Outfit']">
  
  <%- include('partials/sidebar', { currentPage: 'gallery' }) %>

  <!-- Main Content -->
  <main class="md:ml-[280px] min-h-screen sidebar-transition">
    <%- include('partials/topbar', { title: 'Gallery Page Settings' }) %>

    <!-- Page Content -->
    <div class="p-6 md:p-8">
      <div class="glass-card shadow-2xl shadow-slate-200 border border-white rounded-[2.5rem] p-8 md:p-12">
        <div class="text-center mb-12">
          <h3 class="text-3xl font-black text-slate-900 mb-4 bg-gradient-to-r from-emerald-600 to-teal-500 bg-clip-text text-transparent">
            Welcome to Gallery Page Admin Panel
          </h3>
          <p class="text-slate-500 font-medium">Manage your visual showcase and gallery categories.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-4xl mx-auto text-center">
          <!-- Manage Gallery -->
          <div class="group relative p-6 bg-white rounded-3xl border border-slate-100 hover:border-emerald-500/30 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-300">
            <div class="mb-6 flex flex-col items-center">
              <div class="p-4 bg-emerald-50 text-emerald-600 rounded-2xl group-hover:bg-emerald-600 group-hover:text-white transition-all duration-300 mb-4">
                <i class="fas fa-images text-2xl"></i>
              </div>
              <h5 class="text-lg font-bold text-slate-800">Manage Gallery</h5>
            </div>
            <a href="/gallerys" class="inline-flex items-center space-x-2 px-6 py-3 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-emerald-600 transition-all w-full justify-center">
              <span>View Settings</span>
              <i class="fas fa-chevron-right text-[10px]"></i>
            </a>
          </div>

          <!-- Manage Gallery Image -->
          <div class="group relative p-6 bg-white rounded-3xl border border-slate-100 hover:border-emerald-500/30 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-300">
            <div class="mb-6 flex flex-col items-center">
              <div class="p-4 bg-green-50 text-green-600 rounded-2xl group-hover:bg-green-600 group-hover:text-white transition-all duration-300 mb-4">
                <i class="fas fa-camera text-2xl"></i>
              </div>
              <h5 class="text-lg font-bold text-slate-800">Manage Image</h5>
            </div>
            <a href="/gallery_img" class="inline-flex items-center space-x-2 px-6 py-3 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-emerald-600 transition-all w-full justify-center">
              <span>View Settings</span>
              <i class="fas fa-chevron-right text-[10px]"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
