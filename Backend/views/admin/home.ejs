<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="bg-slate-50 text-slate-900 antialiased font-['Outfit']">
  
  <%- include('partials/sidebar', { currentPage: 'home' }) %>

  <!-- Main Content -->
  <main class="md:ml-[280px] min-h-screen sidebar-transition">
    <%- include('partials/topbar', { title: 'Home Page Settings' }) %>

    <!-- Page Content -->
    <div class="p-6 md:p-8">
      <div class="glass-card shadow-2xl shadow-slate-200 border border-white rounded-[2.5rem] p-8 md:p-12">
        <div class="text-center mb-12">
          <h3 class="text-3xl font-black text-slate-900 mb-4 bg-gradient-to-r from-emerald-600 to-teal-500 bg-clip-text text-transparent">
            Welcome to Home Page Admin Panel
          </h3>
          <p class="text-slate-500 font-medium">Configure your main landing page elements here</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Manage Sliders -->
          <div class="group relative p-6 bg-white rounded-3xl border border-slate-100 hover:border-emerald-500/30 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-300">
            <div class="mb-6 flex items-center justify-between">
              <div class="p-4 bg-emerald-50 text-emerald-600 rounded-2xl group-hover:bg-emerald-600 group-hover:text-white transition-all duration-300">
                <i class="fas fa-sliders-h text-2xl"></i>
              </div>
            </div>
            <h5 class="text-lg font-bold text-slate-800 mb-2">Manage Sliders</h5>
            <p class="text-slate-500 text-sm mb-6 leading-relaxed">Update hero background images and text.</p>
            <a href="/slider" class="inline-flex items-center space-x-2 px-6 py-3 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-emerald-600 transition-all w-full justify-center">
              <span>View Settings</span>
              <i class="fas fa-chevron-right text-[10px]"></i>
            </a>
          </div>

          <!-- Manage Plants -->
          <div class="group relative p-6 bg-white rounded-3xl border border-slate-100 hover:border-emerald-500/30 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-300">
            <div class="mb-6 flex items-center justify-between">
              <div class="p-4 bg-green-50 text-green-600 rounded-2xl group-hover:bg-green-600 group-hover:text-white transition-all duration-300">
                <i class="fas fa-seedling text-2xl"></i>
              </div>
            </div>
            <h5 class="text-lg font-bold text-slate-800 mb-2">Manage Plants</h5>
            <p class="text-slate-500 text-sm mb-6 leading-relaxed">Control the biomass plant configurations.</p>
            <a href="/plants" class="inline-flex items-center space-x-2 px-6 py-3 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-emerald-600 transition-all w-full justify-center">
              <span>View Settings</span>
              <i class="fas fa-chevron-right text-[10px]"></i>
            </a>
          </div>

          <!-- Manage Counting -->
          <div class="group relative p-6 bg-white rounded-3xl border border-slate-100 hover:border-emerald-500/30 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-300">
            <div class="mb-6 flex items-center justify-between">
              <div class="p-4 bg-amber-50 text-amber-600 rounded-2xl group-hover:bg-amber-600 group-hover:text-white transition-all duration-300">
                <i class="fas fa-chart-line text-2xl"></i>
              </div>
            </div>
            <h5 class="text-lg font-bold text-slate-800 mb-2">Manage Counting</h5>
            <p class="text-slate-500 text-sm mb-6 leading-relaxed">Update operational stat counters.</p>
            <a href="/counting" class="inline-flex items-center space-x-2 px-6 py-3 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-emerald-600 transition-all w-full justify-center">
              <span>View Settings</span>
              <i class="fas fa-chevron-right text-[10px]"></i>
            </a>
          </div>

          <!-- Working Process -->
          <div class="group relative p-6 bg-white rounded-3xl border border-slate-100 hover:border-emerald-500/30 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-300">
            <div class="mb-6 flex items-center justify-between">
              <div class="p-4 bg-indigo-50 text-indigo-600 rounded-2xl group-hover:bg-indigo-600 group-hover:text-white transition-all duration-300">
                <i class="fas fa-project-diagram text-2xl"></i>
              </div>
            </div>
            <h5 class="text-lg font-bold text-slate-800 mb-2">Working Process</h5>
            <p class="text-slate-500 text-sm mb-6 leading-relaxed">Edit the step-by-step workflow guide.</p>
            <a href="/working" class="inline-flex items-center space-x-2 px-6 py-3 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-emerald-600 transition-all w-full justify-center">
              <span>View Settings</span>
              <i class="fas fa-chevron-right text-[10px]"></i>
            </a>
          </div>

          <!-- Client Support -->
          <div class="group relative p-6 bg-white rounded-3xl border border-slate-100 hover:border-emerald-500/30 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-300">
            <div class="mb-6 flex items-center justify-between">
              <div class="p-4 bg-cyan-50 text-cyan-600 rounded-2xl group-hover:bg-cyan-600 group-hover:text-white transition-all duration-300">
                <i class="fas fa-user-check text-2xl"></i>
              </div>
            </div>
            <h5 class="text-lg font-bold text-slate-800 mb-2">Manage Client</h5>
            <p class="text-slate-500 text-sm mb-6 leading-relaxed">Update client logos and testimonials.</p>
            <a href="/client" class="inline-flex items-center space-x-2 px-6 py-3 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-emerald-600 transition-all w-full justify-center">
              <span>View Settings</span>
              <i class="fas fa-chevron-right text-[10px]"></i>
            </a>
          </div>

          <!-- Machines -->
          <div class="group relative p-6 bg-white rounded-3xl border border-slate-100 hover:border-emerald-500/30 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-300">
            <div class="mb-6 flex items-center justify-between">
              <div class="p-4 bg-rose-50 text-rose-600 rounded-2xl group-hover:bg-rose-600 group-hover:text-white transition-all duration-300">
                <i class="fas fa-tools text-2xl"></i>
              </div>
            </div>
            <h5 class="text-lg font-bold text-slate-800 mb-2">Manage Machines</h5>
            <p class="text-slate-500 text-sm mb-6 leading-relaxed">Information about industrial equipment.</p>
            <a href="/machines" class="inline-flex items-center space-x-2 px-6 py-3 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-emerald-600 transition-all w-full justify-center">
              <span>View Settings</span>
              <i class="fas fa-chevron-right text-[10px]"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
