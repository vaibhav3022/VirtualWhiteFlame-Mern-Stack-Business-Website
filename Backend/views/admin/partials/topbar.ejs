<header class="sticky top-0 bg-white/80 backdrop-blur-md border-b border-slate-200 z-[900] px-4 md:px-8 py-4 flex items-center justify-between">
  <div class="flex items-center space-x-4">
    <button id="openSidebar" class="md:hidden p-2 text-slate-600 hover:bg-slate-100 rounded-xl transition-colors">
      <i class="fas fa-bars text-xl"></i>
    </button>
    <h2 class="text-xl font-bold text-slate-800"><%= title %></h2>
  </div>
  <div class="flex items-center space-x-4">
    <a href="/" class="flex items-center space-x-2 px-4 py-2 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-black transition-all shadow-lg shadow-slate-200">
      <i class="fas fa-external-link-alt"></i>
      <span class="hidden sm:inline">View Site</span>
    </a>
  </div>
</header>
