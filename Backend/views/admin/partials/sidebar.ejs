<aside id="sidebar" class="fixed top-0 left-0 bottom-0 w-[280px] bg-white border-r border-slate-200 z-[1000] sidebar-transition -translate-x-full md:translate-x-0">
  <div class="h-full flex flex-col">
    <div class="p-6 border-b border-slate-50 flex items-center justify-between">
      <a href="/admin" class="flex items-center space-x-3 group">
        <div class="p-1.5 bg-emerald-50 rounded-xl border border-emerald-100 group-hover:scale-110 transition-transform">
          <span class="text-2xl">🌿</span>
        </div>
        <span class="text-xl font-bold bg-gradient-to-r from-emerald-600 to-teal-500 bg-clip-text text-transparent italic">
          AdminPanel
        </span>
      </a>
      <button id="closeSidebar" class="md:hidden p-2 text-slate-500 hover:bg-slate-100 rounded-full transition-colors">
        <i class="fas fa-times text-xl"></i>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto p-4 space-y-2 custom-scrollbar">
      <a href="/home" class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl font-bold transition-all <%= currentPage === 'home' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100/50' : 'text-slate-600 hover:bg-slate-50 hover:text-emerald-600' %>">
        <i class="fas fa-home text-lg"></i>
        <span>Home Page</span>
      </a>
      <a href="/about" class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl font-bold transition-all <%= currentPage === 'about' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100/50' : 'text-slate-600 hover:bg-slate-50 hover:text-emerald-600' %>">
        <i class="fas fa-info-circle text-lg"></i>
        <span>About Page</span>
      </a>
      <a href="/services" class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl font-bold transition-all <%= currentPage === 'services' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100/50' : 'text-slate-600 hover:bg-slate-50 hover:text-emerald-600' %>">
        <i class="fas fa-th-list text-lg"></i>
        <span>Services Page</span>
      </a>
      <a href="/gallery" class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl font-bold transition-all <%= currentPage === 'gallery' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100/50' : 'text-slate-600 hover:bg-slate-50 hover:text-emerald-600' %>">
        <i class="fas fa-images text-lg"></i>
        <span>Gallery Page</span>
      </a>
      <a href="/contact" class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl font-bold transition-all <%= currentPage === 'contact' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100/50' : 'text-slate-600 hover:bg-slate-50 hover:text-emerald-600' %>">
        <i class="fas fa-envelope text-lg"></i>
        <span>Contact Page</span>
      </a>
    </nav>

    <div class="p-6 border-t border-slate-50">
      <div class="bg-slate-50 rounded-2xl p-4 flex items-center space-x-3 mb-4">
        <div class="w-10 h-10 rounded-full bg-emerald-600 flex items-center justify-center text-white font-bold">A</div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-bold text-slate-900 truncate">Administrator</p>
          <p class="text-xs text-emerald-600">Super Admin</p>
        </div>
      </div>
      <a href="/logout" class="flex items-center justify-center space-x-2 w-full py-3 bg-red-50 text-red-600 rounded-xl text-sm font-bold hover:bg-red-100 hover:text-red-700 transition-all border border-red-100">
        <i class="fas fa-sign-out-alt text-xs"></i>
        <span>Logout Account</span>
      </a>
    </div>
  </div>
</aside>
<div id="sidebarOverlay" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[990] hidden md:hidden transition-opacity duration-300"></div>
