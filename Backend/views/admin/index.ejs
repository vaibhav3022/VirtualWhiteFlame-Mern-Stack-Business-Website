<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <style>
    body {
      font-family: "Poppins", sans-serif;
      background-color: #f5f6fa;
      overflow-x: hidden;
    }

    /* Sidebar Styling */
    .sidebar {
      height: 100vh;
      width: 250px;
      background: #ffffff;
      border-right: 1px solid #dee2e6;
      position: fixed;
      top: 0;
      left: 0;
      overflow-y: auto;
      transition: all 0.3s ease;
      z-index: 1000;
    }

    .sidebar .navbar-brand {
      font-size: 1.5rem;
      color: #0d6efd;
    }

    .sidebar .nav-link {
      color: #333;
      font-weight: 500;
      padding: 12px 20px;
      transition: all 0.2s ease-in-out;
    }

    .sidebar .nav-link:hover,
    .sidebar .nav-link.active {
      background-color: #0d6efd;
      color: #fff;
      border-radius: 5px;
    }

    .sidebar .nav-link i {
      margin-right: 10px;
    }

    /* Content Area */
    .content {
      margin-left: 250px;
      padding: 40px 20px;
      transition: all 0.3s ease;
    }

    /* Top Navbar */
    .topbar {
      background-color: #0d6efd;
      color: #fff;
      padding: 12px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 900;
    }

    .topbar .toggle-btn {
      font-size: 1.4rem;
      cursor: pointer;
    }

    /* Welcome Card */
    .welcome-card {
      background: linear-gradient(135deg, #12b886, #0d6efd);
      color: #fff;
      border-radius: 15px;
      padding: 60px 30px;
      text-align: center;
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
      transition: transform 0.3s ease;
    }

    .welcome-card:hover {
      transform: translateY(-5px);
    }

    .welcome-card h1 {
      font-size: 2.5rem;
      margin-bottom: 15px;
    }

    .welcome-card p {
      font-size: 1.2rem;
      opacity: 0.9;
    }

    /* Responsive */
    @media (max-width: 991px) {
      .sidebar {
        left: -250px;
      }
      .sidebar.active {
        left: 0;
      }
      .content {
        margin-left: 0;
      }
    }
  </style>
</head>
<body>

  <!-- Sidebar -->
  <nav class="sidebar" id="sidebarMenu">
    <div class="text-center py-3 border-bottom">
      <a class="navbar-brand fw-bold" href="/">🌿 Admin</a>
    </div>

    <ul class="nav flex-column px-2 mt-3">
      <li class="nav-item">
        <a class="nav-link active" href="/home"><i class="fas fa-sliders-h"></i> Home Page</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/about"><i class="fas fa-seedling"></i> About Page</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/services"><i class="fas fa-chart-bar"></i> Services Page</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/gallery"><i class="fas fa-cogs"></i> Gallery Page</a>
      </li>
       <li class="nav-item">
        <a class="nav-link" href="/contact"><i class="fas fa-cogs"></i> Contact Page</a>
      </li>
    </ul>
  </nav>

  <!-- Top Navbar -->
  <div class="topbar">
    <span class="toggle-btn text-white" id="menuToggle"><i class="fas fa-bars"></i></span>
    <h5 class="mb-0">Admin Dashboard</h5>
    <div>
      <i class="fas fa-user-circle fs-4 me-3"></i>
    </div>
  </div>

  <!-- Content -->
  <div class="content">
    <div class="welcome-card">
      <h1>Welcome to Admin Dashboard</h1>
      <p>Manage your website content and monitor activities easily</p>
    </div>
  </div>

  <!-- Sidebar toggle for mobile -->
  <script>
    const menuToggle = document.getElementById('menuToggle');
    const sidebarMenu = document.getElementById('sidebarMenu');
    menuToggle.addEventListener('click', () => {
      sidebarMenu.classList.toggle('active');
    });
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
