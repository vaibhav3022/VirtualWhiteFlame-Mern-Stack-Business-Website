<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="bg-slate-50 text-slate-900 antialiased font-['Outfit']">
  
  <%- include('partials/sidebar', { currentPage: 'index' }) %>

  <!-- Main Content -->
  <main class="md:ml-[280px] min-h-screen sidebar-transition">
    <%- include('partials/topbar', { title: 'Dashboard' }) %>

    <!-- Page Content -->
    <div class="p-6 md:p-8">
      <!-- Welcome Banner -->
      <div class="relative overflow-hidden rounded-[2.5rem] bg-slate-950 p-8 md:p-12 mb-8 group shadow-2xl shadow-slate-200">
        <div class="absolute top-0 right-0 w-96 h-96 bg-emerald-500/10 rounded-full blur-[100px] -mr-32 -mt-32"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-teal-500/10 rounded-full blur-[80px] -ml-20 -mb-20"></div>
        
        <div class="relative z-10 max-w-2xl text-center md:text-left mx-auto md:mx-0">
          <span class="inline-flex items-center space-x-2 px-3 py-1 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-emerald-400 text-xs font-bold uppercase tracking-widest mb-6">
            <i class="fas fa-sparkles text-[10px]"></i>
            <span>System Status: Online</span>
          </span>
          <h1 class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight">
            Welcome back, <span class="bg-gradient-to-r from-emerald-400 to-teal-300 bg-clip-text text-transparent italic">Administrator</span>
          </h1>
          <p class="text-slate-400 text-lg leading-relaxed mb-8 font-medium">
            Manage your website content, update services, and monitor your visual gallery all from one central command center.
          </p>
          <div class="flex flex-wrap justify-center md:justify-start gap-4">
            <a href="/home" class="px-8 py-4 bg-emerald-600 hover:bg-emerald-700 text-white rounded-2xl font-bold transition-all shadow-xl shadow-emerald-500/20 flex items-center space-x-3 group">
              <span>Go to Settings</span>
              <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform"></i>
            </a>
          </div>
        </div>
      </div>

      <!-- Quick Stats / Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Home Section Card -->
        <a href="/home" class="glass-card p-6 rounded-[2rem] border border-slate-100 hover:border-emerald-500/40 hover:shadow-xl hover:shadow-emerald-500/5 transition-all duration-300 group">
          <div class="flex items-center justify-between mb-4">
            <div class="p-4 bg-emerald-50 text-emerald-600 rounded-2xl group-hover:scale-110 group-hover:bg-emerald-600 group-hover:text-white transition-all duration-300">
              <i class="fas fa-home text-xl"></i>
            </div>
            <i class="fas fa-chevron-right text-slate-300 group-hover:text-emerald-500 transition-colors"></i>
          </div>
          <h3 class="text-xl font-bold text-slate-800 mb-2">Home Page</h3>
          <p class="text-slate-500 text-sm font-medium">Manage sliders, plants, and counters.</p>
        </a>

        <!-- Services Section Card -->
        <a href="/services" class="glass-card p-6 rounded-[2rem] border border-slate-100 hover:border-emerald-500/40 hover:shadow-xl hover:shadow-emerald-500/5 transition-all duration-300 group">
          <div class="flex items-center justify-between mb-4">
            <div class="p-4 bg-blue-50 text-emerald-600 rounded-2xl group-hover:scale-110 group-hover:bg-emerald-600 group-hover:text-white transition-all duration-300">
              <i class="fas fa-th-list text-xl"></i>
            </div>
            <i class="fas fa-chevron-right text-slate-300 group-hover:text-emerald-500 transition-colors"></i>
          </div>
          <h3 class="text-xl font-bold text-slate-800 mb-2">Services</h3>
          <p class="text-slate-500 text-sm font-medium">Update specialized industrial offerings.</p>
        </a>

        <!-- Contact Section Card -->
        <a href="/contact" class="glass-card p-6 rounded-[2rem] border border-slate-100 hover:border-emerald-500/40 hover:shadow-xl hover:shadow-emerald-500/5 transition-all duration-300 group">
          <div class="flex items-center justify-between mb-4">
            <div class="p-4 bg-purple-50 text-emerald-600 rounded-2xl group-hover:scale-110 group-hover:bg-emerald-600 group-hover:text-white transition-all duration-300">
              <i class="fas fa-envelope text-xl"></i>
            </div>
            <i class="fas fa-chevron-right text-slate-300 group-hover:text-emerald-500 transition-colors"></i>
          </div>
          <h3 class="text-xl font-bold text-slate-800 mb-2">Contact</h3>
          <p class="text-slate-500 text-sm font-medium">Manage inquiries and contact details.</p>
        </a>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
