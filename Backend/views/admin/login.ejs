<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login | Virtual White Flame</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Outfit', sans-serif; }
    .bg-mesh {
      background-color: #f8fafc;
      background-image: 
        radial-gradient(at 0% 0%, rgba(16, 185, 129, 0.05) 0px, transparent 50%),
        radial-gradient(at 100% 0%, rgba(6, 182, 212, 0.05) 0px, transparent 50%);
    }
    .glass-card {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.4);
    }
    .gradient-text {
      background: linear-gradient(135deg, #059669 0%, #0d9488 100%);
      background-clip: text;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .premium-button {
      background: linear-gradient(135deg, #059669 0%, #0d9488 100%);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .premium-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px -5px rgba(5, 150, 105, 0.4);
    }
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      75% { transform: translateX(5px); }
    }
    .animate-shake { animation: shake 0.2s ease-in-out 0s 2; }
  </style>
</head>
<body class="min-h-screen bg-mesh flex items-center justify-center p-4">
  <!-- Decorative Orbs -->
  <div class="fixed top-0 left-0 -ml-20 -mt-20 w-80 h-80 bg-emerald-500/10 rounded-full blur-[120px]"></div>
  <div class="fixed bottom-0 right-0 -mr-20 -mb-20 w-80 h-80 bg-cyan-500/10 rounded-full blur-[120px]"></div>

  <div class="max-w-md w-full space-y-8 glass-card p-10 relative z-10 border border-white/40 shadow-2xl rounded-[2.5rem]">
    <div class="text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-emerald-50 rounded-3xl mb-6">
        <i class="fas fa-user-shield text-4xl text-emerald-600"></i>
      </div>
      <h2 class="text-3xl font-black text-slate-900 tracking-tight">Admin Portal</h2>
      <p class="mt-2 text-sm text-slate-600 font-medium">
        Welcome back to <span class="gradient-text font-bold">Virtual White Flame</span>
      </p>
    </div>

    <% if (error) { %>
      <div class="bg-red-50 border border-red-100 text-red-600 px-4 py-3 rounded-2xl text-sm font-semibold animate-shake flex items-center gap-3">
        <i class="fas fa-exclamation-circle"></i>
        <%= error %>
      </div>
    <% } %>

    <form class="mt-8 space-y-6" action="/login" method="POST">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2 ml-1" for="username">Username</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400">
              <i class="fas fa-user text-xs"></i>
            </span>
            <input
              id="username"
              name="username"
              type="text"
              required
              class="block w-full pl-10 pr-4 py-4 rounded-2xl bg-white/50 border border-slate-200 focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/10 transition-all outline-none text-slate-900 placeholder-slate-400 font-medium"
              placeholder="Enter admin username"
            >
          </div>
        </div>

        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2 ml-1" for="password">Password</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400">
              <i class="fas fa-lock text-xs"></i>
            </span>
            <input
              id="password"
              name="password"
              type="password"
              required
              class="block w-full pl-10 pr-4 py-4 rounded-2xl bg-white/50 border border-slate-200 focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/10 transition-all outline-none text-slate-900 placeholder-slate-400 font-medium"
              placeholder="••••••••"
            >
          </div>
        </div>
      </div>

      <div>
        <button
          type="submit"
          class="w-full premium-button py-4 rounded-2xl text-white text-lg font-bold flex items-center justify-center gap-2 group"
        >
          <span>Sign In to Dashboard</span>
          <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform"></i>
        </button>
      </div>
    </form>

    <div class="text-center pt-4">
      <p class="text-xs text-slate-400 font-medium">
        Secure Access Only • Powered by Virtual White Flame
      </p>
    </div>
  </div>
</body>
</html>
