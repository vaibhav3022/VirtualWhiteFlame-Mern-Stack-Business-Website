<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Add Slider</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
      <a href="/" class="navbar-brand">⬅ Back to Home</a>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="card shadow border-0">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="fas fa-plus-circle"></i> Add New Slider</h4>
      </div>
      <div class="card-body">
        <form action="/save_slider" method="post" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label fw-bold">Slider Title</label>
            <input type="text" name="slider_title" class="form-control" placeholder="Enter slider title" required>
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">Slider Image 1</label>
              <input type="file" name="img1" class="form-control" accept="image/*" required>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">Slider Image 2</label>
              <input type="file" name="img2" class="form-control" accept="image/*" required>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">Slider Image 3</label>
              <input type="file" name="img3" class="form-control" accept="image/*" required>
            </div>
          </div>

          <button class="btn btn-primary w-100 mt-3">Add Slider</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
