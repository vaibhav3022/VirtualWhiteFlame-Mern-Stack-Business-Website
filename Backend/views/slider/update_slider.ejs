<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Update Slider</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
      <a href="/list_slider" class="navbar-brand">⬅ Back to List</a>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="card shadow border-0">
      <div class="card-header bg-warning text-white">
        <h4 class="mb-0"><i class="fas fa-edit"></i> Update Slider</h4>
      </div>
      <div class="card-body">
        <form action="/update_slider" method="post" enctype="multipart/form-data">
          <input type="hidden" name="id" value="<%= result[0].id %>">

          <!-- Slider Title -->
          <div class="mb-3">
            <label class="form-label fw-bold">Slider Title</label>
            <input type="text" name="slider_title" class="form-control" 
                   value="<%= result[0].slider_title %>" required>
          </div>

          <!-- Slider Images -->
          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">Slider Image 1</label>
              <input type="file" name="img1" class="form-control" accept="image/*">
              <br>
              <img src="/<%= result[0].img1 %>" alt="Image 1" class="img-thumbnail" width="150">
            </div>

            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">Slider Image 2</label>
              <input type="file" name="img2" class="form-control" accept="image/*">
              <br>
              <img src="/<%= result[0].img2 %>" alt="Image 2" class="img-thumbnail" width="150">
            </div>

            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">Slider Image 3</label>
              <input type="file" name="img3" class="form-control" accept="image/*">
              <br>
              <img src="/<%= result[0].img3 %>" alt="Image 3" class="img-thumbnail" width="150">
            </div>
          </div>

          <button class="btn btn-warning w-100 mt-3">Update Slider</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
