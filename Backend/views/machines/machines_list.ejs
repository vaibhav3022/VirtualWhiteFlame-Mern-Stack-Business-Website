<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Machines List</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a href="/" class="navbar-brand">⬅ Back to Home</a>
     <a href="/add_machines" class="navbar-brand">⬅ Add New Machines</a>
  </div>
</nav>

<div class="container mt-5">
  <h3 class="mb-4 fw-bold">All Machines</h3>

  <table class="table table-bordered table-striped">
    <thead class="table-dark">
      <tr>
        <th>ID</th>
        <th>Machine Name</th>
        <th>Description</th>
        <th>Image</th>
        <th>Action</th>
      </tr>
    </thead>

    <tbody>
      <% result.forEach(item => { %>
        <tr>
          <td><%= item.id %></td>
          <td><%= item.machines_name %></td>
          <td><%= item.machines_dec %></td>
          <td>
            <img src="/<%= item.working_img %>" width="80">
          </td>

          <td>
            <a href="/edit_machines/<%= item.id %>" class="btn btn-warning btn-sm">Edit</a>
            <a href="/delete_machines/<%= item.id %>" class="btn btn-danger btn-sm">Delete</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

</body>
</html>
