<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Edit Machine</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a href="/machines_list" class="navbar-brand">⬅ Back to List</a>
  </div>
</nav>

<div class="container mt-5">
  <div class="card shadow border-0">
    <div class="card-header bg-warning text-white">
      <h4>Edit Machine</h4>
    </div>

    <div class="card-body">
      <form action="/update_machines" method="post" enctype="multipart/form-data">

        <input type="hidden" name="id" value="<%= result[0].id %>">

        <div class="mb-3">
          <label class="form-label fw-bold">Machine Name</label>
          <input type="text" name="machines_name" value="<%= result[0].machines_name %>" class="form-control">
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Machine Description</label>
          <textarea name="machines_dec" class="form-control"><%= result[0].machines_dec %></textarea>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Machine Image</label>
          <input type="file" name="working_img" class="form-control">
          <p class="mt-2">Current Image:</p>
          <img src="/<%= result[0].working_img %>" width="120">
        </div>

        <button class="btn btn-warning w-100">Update Machine</button>

      </form>

    </div>
  </div>
</div>

</body>
</html>
