<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add About</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a href="/about" class="navbar-brand">⬅ Back</a>
  </div>
</nav>

<div class="container mt-5">
  <div class="card shadow border-0">
    <div class="card-header bg-primary text-white">
      <h4>Add About Section</h4>
    </div>

    <div class="card-body">
      <form action="/save_about" method="post" enctype="multipart/form-data">

        <div class="mb-3">
          <label class="form-label fw-bold">About Heading</label>
          <input type="text" name="about_heading" class="form-control" required>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">About Description</label>
          <textarea name="about_desc" class="form-control" required></textarea>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Image</label>
          <input type="file" name="about_img" class="form-control" required>
        </div>

        <button class="btn btn-primary w-100">Add About</button>

      </form>
    </div>
  </div>
</div>

</body>
</html>
