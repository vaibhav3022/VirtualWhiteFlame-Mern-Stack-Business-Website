<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>About List</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a href="/about" class="navbar-brand">⬅ Back</a>
    <a href="/add_about" class="navbar-brand">+ Add About</a>
  </div>
</nav>

<div class="container mt-5">
  <h3 class="mb-4 fw-bold">About Records</h3>

  <table class="table table-bordered table-striped">
    <thead class="table-dark">
      <tr>
        <th>ID</th>
        <th>Heading</th>
        <th>Description</th>
        <th>Image</th>
        <th>Action</th>
      </tr>
    </thead>

    <tbody>
      <% result.forEach(item => { %>
        <tr>
          <td><%= item.id %></td>
          <td><%= item.about_heading %></td>
          <td><%= item.about_desc %></td>
          <td><img src="/<%= item.about_img %>" width="80"></td>
          <td>
            <a href="/edit_about/<%= item.id %>" class="btn btn-warning btn-sm">Edit</a>
            <a href="/delete_about/<%= item.id %>" class="btn btn-danger btn-sm">Delete</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

</body>
</html>
