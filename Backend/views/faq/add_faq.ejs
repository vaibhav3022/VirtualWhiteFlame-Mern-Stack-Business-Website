<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add FAQ</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a href="/faq_home" class="navbar-brand">⬅ Back</a>
  </div>
</nav>

<div class="container mt-5">
  <div class="card shadow border-0">
    <div class="card-header bg-primary text-white">
      <h4>Add FAQ</h4>
    </div>

    <div class="card-body">
      <form action="/save_faq" method="post">

        <div class="mb-3">
          <label class="form-label fw-bold">Question</label>
          <textarea name="que" class="form-control" required></textarea>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Answer</label>
          <textarea name="ans" class="form-control" required></textarea>
        </div>

        <button class="btn btn-primary w-100">Add FAQ</button>

      </form>
    </div>
  </div>
</div>

</body>
</html>
