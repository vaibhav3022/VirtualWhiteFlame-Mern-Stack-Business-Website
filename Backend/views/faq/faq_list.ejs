<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>FAQ List</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a href="/faq" class="navbar-brand">⬅ Back</a>
    <a href="/add_faq" class="navbar-brand">+ Add FAQ</a>
  </div>
</nav>

<div class="container mt-5">
  <h3 class="mb-4 fw-bold">FAQ Records</h3>

  <table class="table table-bordered table-striped">
    <thead class="table-dark">
      <tr>
        <th>ID</th>
        <th>Question</th>
        <th>Answer</th>
        <th>Action</th>
      </tr>
    </thead>

    <tbody>
      <% result.forEach(item => { %>
        <tr>
          <td><%= item.id %></td>
          <td><%= item.que %></td>
          <td><%= item.ans %></td>

          <td>
            <a href="/edit_faq/<%= item.id %>" class="btn btn-warning btn-sm">Edit</a>
            <a href="/delete_faq/<%= item.id %>" class="btn btn-danger btn-sm">Delete</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

</body>
</html>
