<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit FAQ</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a href="/faq_list" class="navbar-brand">⬅ Back</a>
  </div>
</nav>

<div class="container mt-5">
  <div class="card shadow border-0">
    <div class="card-header bg-warning text-white">
      <h4>Edit FAQ</h4>
    </div>

    <div class="card-body">
      <form action="/update_faq" method="post">

        <input type="hidden" name="id" value="<%= result[0].id %>">

        <div class="mb-3">
          <label class="form-label fw-bold">Question</label>
          <textarea name="que" class="form-control"><%= result[0].que %></textarea>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Answer</label>
          <textarea name="ans" class="form-control"><%= result[0].ans %></textarea>
        </div>

        <button class="btn btn-warning w-100 mt-3">Update FAQ</button>

      </form>
    </div>
  </div>
</div>

</body>
</html>
