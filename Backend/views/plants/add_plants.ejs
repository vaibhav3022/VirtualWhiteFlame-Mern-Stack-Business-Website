<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Add Slider</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
      <a href="/" class="navbar-brand">⬅ Back to Home</a>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="card shadow border-0">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="fas fa-plus-circle"></i> Add New Plants</h4>
      </div>
      <div class="card-body">
        <form action="/save_plants" method="post" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label fw-bold">Plants Name</label>
            <input type="text" name="plants_name" class="form-control" placeholder="Enter Plants Name" required>
          </div>

           <div class="mb-3">
            <label class="form-label fw-bold">Plants Address</label>
            <input type="textarea" name="plants_add" class="form-control" placeholder="Enter Plants Address" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Plants Mobile</label>
            <input type="textarea" name="plants_mobile" class="form-control" placeholder="Enter Plants Mobile" required>
          </div>
          
          <div class="mb-3">
            <label class="form-label fw-bold">Plants Email</label>
            <input type="textarea" name="plants_email" class="form-control" placeholder="Enter Plants Email" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Description</label>
            <textarea name="plants_desc" class="form-control" rows="3" placeholder="Enter Plants Description"></textarea>
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">Slider Image 1</label>
              <input type="file" name="plants_img" class="form-control" accept="image/*" required>
            </div>
          </div>

          <button class="btn btn-primary w-100 mt-3">Add Plants</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>


