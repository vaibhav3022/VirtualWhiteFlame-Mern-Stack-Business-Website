<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Update Slider</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
      <a href="/plants_slider" class="navbar-brand">⬅ Back to List</a>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="card shadow border-0">
      <div class="card-header bg-warning text-white">
        <h4 class="mb-0"><i class="fas fa-edit"></i> Update Plants</h4>
      </div>
      <div class="card-body">
        <form action="/update_plants" method="post" enctype="multipart/form-data">
          <input type="hidden" name="id" value="<%= result[0].id %>">

          <div class="mb-3">
            <label class="form-label fw-bold">Plants Name</label>
            <input type="text" name="plants_name" class="form-control" value="<%= result[0].plants_name %>">
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Plants Address</label>
            <input type="text" name="plants_add" class="form-control" value="<%= result[0].plants_add %>">
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Plants Email</label>
            <input type="text" name="plants_email" class="form-control" value="<%= result[0].plants_email %>">
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Plants Mobile</label>
            <input type="text" name="plants_mobile" class="form-control" value="<%= result[0].plants_mobile %>">
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">Plants Image</label>
              <input type="file" name="plants_img" class="form-control" accept="image/*">
            </div>
          </div>

          <button class="btn btn-warning w-100 mt-3">Update Plants</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
